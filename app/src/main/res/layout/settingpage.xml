<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:id="@+id/main"
    android:background="@color/eggshell_bg"
    android:padding="24dp">

    <TextView
        android:id="@+id/texttitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Settings"
        android:textColor="@color/black_ink"
        android:textSize="32sp"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="32dp" />

    <TextView
        android:id="@+id/headerpreferences"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Preferences"
        android:textColor="@color/black_ink"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginTop="32dp"
        app:layout_constraintTop_toBottomOf="@id/texttitle"
        app:layout_constraintStart_toStartOf="parent" />

    <TextView
        android:id="@+id/labelmusiccontrol"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Music Control"
        android:textColor="@color/black_ink"
        android:textSize="16sp"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/headerpreferences"
        app:layout_constraintStart_toStartOf="parent" />

    <Switch
        android:id="@+id/switchmusiccontrol"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:checked="false"
        android:minWidth="60dp"
        android:minHeight="40dp"
        android:thumbTint="@color/black_ink"
        android:trackTint="#CCCCCC"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/labelmusiccontrol"
        app:layout_constraintBottom_toBottomOf="@id/labelmusiccontrol" />

    <TextView
        android:id="@+id/labelchoosepieces"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Choose Pieces"
        android:textColor="@color/black_ink"
        android:textSize="16sp"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toBottomOf="@id/labelmusiccontrol"
        app:layout_constraintStart_toStartOf="parent" />

    <RadioGroup
        android:id="@+id/radiogrouppieces"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/labelchoosepieces"
        app:layout_constraintStart_toStartOf="parent">

        <RadioButton
            android:id="@+id/radioblack"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Black"
            android:checked="false"
            android:textColor="@color/black_ink"
            android:buttonTint="@color/black_ink"
            android:layout_marginEnd="16dp" />

        <RadioButton
            android:id="@+id/radiowhite"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="White"
            android:checked="false"
            android:textColor="@color/black_ink"
            android:buttonTint="@color/black_ink" />
    </RadioGroup>

    <TextView
        android:id="@+id/headeraccount"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Account"
        android:textColor="@color/black_ink"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginTop="32dp"
        app:layout_constraintTop_toBottomOf="@id/radiogrouppieces"
        app:layout_constraintStart_toStartOf="parent" />

    <TextView
        android:id="@+id/labeleditusername"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Edit Username"
        android:textColor="@color/black_ink"
        android:textSize="16sp"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/headeraccount"
        app:layout_constraintStart_toStartOf="parent" />

    <EditText
        android:id="@+id/editusername"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:inputType="textPersonName"
        android:hint="Enter new username..."
        android:text=""
        android:textColor="@color/black_ink"
        android:textColorHint="@color/black_ink"
        android:background="@drawable/edittext_border_black"
        android:padding="12dp"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/labeleditusername"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/headerdangerzone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Danger Zone"
        android:textColor="@color/black_ink"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginTop="32dp"
        app:layout_constraintTop_toBottomOf="@id/editusername"
        app:layout_constraintStart_toStartOf="parent" />

    <TextView
        android:id="@+id/textdeletewarning"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Once you delete your account, there is no going back. Please be certain."
        android:textColor="@color/black_ink"
        android:textSize="14sp"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/headerdangerzone"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <Button
        android:id="@+id/btn_delete_account"
        style="@style/Widget.AppCompat.Button.Borderless"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Delete Account"
        android:textColor="@color/black_ink"
        android:textSize="16sp"
        android:textStyle="bold"
        android:background="@drawable/button_border_black"
        android:paddingVertical="12dp"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/textdeletewarning"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <ImageButton
        android:id="@+id/backbtn"
        android:layout_width="96dp"
        android:layout_height="81dp"
        android:background="@null"
        android:scaleType="fitXY"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.978"
        app:srcCompat="@drawable/backbtn" />

</androidx.constraintlayout.widget.ConstraintLayout>